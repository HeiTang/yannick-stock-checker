---
import '../styles/query.css';
import '../styles/landing.css';
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>亞尼克・庫存雷達 · YTM Stock Radar</title>
    <meta
      name="description"
      content="非官方 YTM 生乳捲庫存查詢工具：以商品為核心、即時反查全台仍有現貨的站點，並可由站點視角直接看在庫商品。"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#120A11" />
    <link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/regular/style.css" />
    <link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/bold/style.css" />
    <link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/fill/style.css" />
  </head>
  <body>
    <div class="yt-page" id="yt-page">
      <div class="yt-shell" id="yt-shell"></div>
    </div>

    <script>
      import { initLanding } from '../scripts/landing.ts';
      document.addEventListener('DOMContentLoaded', () => {
        initLanding({ shellSelector: '#yt-shell', pageSelector: '#yt-page' });
      });
    </script>
  </body>
</html>
